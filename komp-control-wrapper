#!/bin/bash

# Komp TimeTracker wrapper script for Flatpak
# This handles environment setup, dependency checks, and runs the CLI

# Set up environment for Flatpak
export PYTHONPATH=/app/share/komp-timetracker

# Set config and database paths
export KOMP_CONFIG=${XDG_CONFIG_HOME:-$HOME/.config}/komp-timetracker/config.yaml
export KOMP_DB=${XDG_DATA_HOME:-$HOME/.local/share}/komp-timetracker/usage.db

# Create config directory if it doesn't exist
mkdir -p "$(dirname "$KOMP_CONFIG")"

# Copy default config if none exists
if [ ! -f "$KOMP_CONFIG" ]; then
    # Check if default config exists in app directory
    if [ -f /app/share/komp-timetracker/komp_timetracker/default-config.yaml ]; then
        cp /app/share/komp-timetracker/komp_timetracker/default-config.yaml "$KOMP_CONFIG"
    elif [ -f /app/share/komp-timetracker/komp_timetracker/config.yaml ]; then
        cp /app/share/komp-timetracker/komp_timetracker/config.yaml "$KOMP_CONFIG"
    elif [ -f /app/share/komp-timetracker/config.yaml ]; then
        cp /app/share/komp-timetracker/config.yaml "$KOMP_CONFIG"
    else
        # Create a minimal default config
        cat > "$KOMP_CONFIG" << 'EOF'
system:
  enforcement_method: "flatpak"
  grace_period: "5m"
  monitoring_enabled: true
  data_retention_days: 30

users: {}

monitoring:
  track_apps: true
  track_web: true
  retention_days: 30
EOF
    fi
fi

# Check for required Python modules and install if missing
check_python_module() {
    local module=$1
    if ! python3 -c "import $module" 2>/dev/null; then
        echo "Installing missing Python module: $module"
        if pip3 install --user "$module" 2>/dev/null; then
            echo "Successfully installed $module"
        else
            echo "Warning: Could not install $module automatically"
            echo "Please install manually: pip3 install --user $module"
        fi
    fi
}

# Check for required modules
check_python_module pyyaml
check_python_module pydantic
check_python_module click
check_python_module rich
check_python_module psutil
check_python_module systemd-python
check_python_module python-dateutil
check_python_module pytz

# Run the CLI from the app directory
cd /app/share/komp-timetracker
python3 -m komp_timetracker.ui.cli "$@"
