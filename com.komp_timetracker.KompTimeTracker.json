{
  "app-id": "com.komp_timetracker.KompTimeTracker",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "22.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "komp-control",
  "finish-args": [
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=ipc",
    "--share=network",
    "--filesystem=host",
    "--filesystem=xdg-config/komp-timetracker:create",
    "--filesystem=xdg-data/komp-timetracker:create",
    "--filesystem=xdg-cache/komp-timetracker:create",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.DBus.Properties",
    "--talk-name=org.freedesktop.login1",
    "--system-talk-name=org.freedesktop.login1",
    "--device=dri"
  ],
  "build-options": {
    "cflags": "-O2 -g",
    "cxxflags": "-O2 -g",
    "ldflags": "-Wl,-O1 -Wl,--as-needed",
    "build-args": ["--share=network"]
  },
  "modules": [
    {
      "name": "komp-timetracker",
      "buildsystem": "simple",
      "build-commands": [
        "# Create directory structure for Python package",
        "mkdir -p /app/bin /app/lib /app/share/komp-timetracker/komp_timetracker /app/share/applications",
        
        "# Copy all source files to komp_timetracker package directory",
        "cp -r . /app/share/komp-timetracker/komp_timetracker/",
        
        "# Remove the wrapper from the package directory (it goes to /app/bin)",
        "rm -f /app/share/komp-timetracker/komp_timetracker/komp-control-wrapper",
        
        "# Remove config.yaml from package directory (we'll copy it as default-config.yaml)",
        "rm -f /app/share/komp-timetracker/komp_timetracker/config.yaml",
        
        "# Copy config file as default-config.yaml",
        "cp config.yaml /app/share/komp-timetracker/komp_timetracker/default-config.yaml",
        
        "# Install wrapper as komp-control",
        "cp komp-control-wrapper /app/bin/komp-control",
        "chmod +x /app/bin/komp-control",
        
        "# Create desktop file",
        "printf '[Desktop Entry]\nVersion=1.0\nType=Application\nName=Komp TimeTracker\nComment=Parental Control for Bazzite Linux\nExec=komp-control status\nTerminal=true\nCategories=Utility;Security;System;\n' > /app/share/applications/com.komp_timetracker.KompTimeTracker.desktop",
        
        "# Install Python dependencies using the SDK's pip into /app/lib",
        "pip3 install --prefix=/app --no-cache-dir pyyaml pydantic click rich psutil systemd-python dbus-python",
        
        "# Clean up any __pycache__",
        "find /app/share/komp-timetracker -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "src"
        },
        {
          "type": "file",
          "path": "config.yaml"
        },
        {
          "type": "file",
          "path": "komp-control-wrapper"
        },
        {
          "type": "file",
          "path": "requirements.txt"
        }
      ]
    }
  ]
}
