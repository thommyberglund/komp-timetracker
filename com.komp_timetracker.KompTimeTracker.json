{
  "app-id": "com.komp_timetracker.KompTimeTracker",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "22.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "komp-control",
  "finish-args": [
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=ipc",
    "--share=network",
    "--filesystem=host",
    "--filesystem=xdg-config/komp-timetracker:create",
    "--filesystem=xdg-data/komp-timetracker:create",
    "--filesystem=xdg-cache/komp-timetracker:create",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.DBus.Properties",
    "--talk-name=org.freedesktop.login1",
    "--system-talk-name=org.freedesktop.login1",
    "--device=dri"
  ],
  "build-options": {
    "cflags": "-O2 -g",
    "cxxflags": "-O2 -g",
    "ldflags": "-Wl,-O1 -Wl,--as-needed"
  },
  "modules": [
    {
      "name": "komp-timetracker",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin /app/share/komp-timetracker /app/share/applications",
        "# Create the komp_timetracker package directory",
        "mkdir -p /app/share/komp-timetracker/komp_timetracker",
        "# Copy all source files to the package directory",
        "cp -r src/* /app/share/komp-timetracker/komp_timetracker/",
        "# Copy the __init__.py from src root",
        "cp src/__init__.py /app/share/komp-timetracker/komp_timetracker/",
        "# Copy config file",
        "cp config.yaml /app/share/komp-timetracker/komp_timetracker/default-config.yaml",
        "# Install wrapper as komp-control",
        "cp komp-control-wrapper /app/bin/komp-control",
        "chmod +x /app/bin/komp-control",
        "# Create desktop file",
        "printf '[Desktop Entry]\nVersion=1.0\nType=Application\nName=Komp TimeTracker\nComment=Parental Control for Bazzite Linux\nExec=komp-control status\nTerminal=true\nCategories=Utility;Security;System;\n' > /app/share/applications/com.komp_timetracker.KompTimeTracker.desktop"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "src"
        },
        {
          "type": "file",
          "path": "config.yaml"
        },
        {
          "type": "file",
          "path": "komp-control-wrapper"
        }
      ]
    }
  ]
}
